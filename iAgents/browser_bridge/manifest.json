{
  "manifest_version": 3,
  "name": "iAgents Excel Online Bridge",
  "version": "0.1.0",
  "description": "Relay Excel Online state to the local iAgents assistant.",
  "permissions": ["tabs"],
  "host_permissions": [
    "https://*.office.com/*",
    "https://excel.cloud.microsoft/*",
    "http://127.0.0.1:8765/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.office.com/*",
        "https://excel.cloud.microsoft/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "iAgents Bridge"
  }
}
